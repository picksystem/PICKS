# ================================
# PICKS - Environment Variables Template
# ================================
# Copy this file to .env and fill in the actual values
# This file is safe to commit to version control
# Last Updated: 2026-01-29
# ================================

# ============================================
# BACKEND SERVER CONFIGURATION
# ============================================

# Environment
NODE_ENV=development

# Server (Unified API on single port)
PORT=3001
HOST=localhost

# Database
# Note: Special characters in password must be URL-encoded (& becomes %26)
DATABASE_URL=postgresql://postgres:password@localhost:5432/picks_db?schema=public

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Redis (Optional - Server starts without Redis if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
ENABLE_CONSOLE_LOGS=true

# CORS
CORS_ORIGIN=http://localhost:1500,http://localhost:1400

# ============================================
# EMAIL / SMTP CONFIGURATION
# ============================================
# For Gmail: Use an App Password (not regular password)
# 1. Enable 2FA on your Google account
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=PICKS App <noreply@picks.com>

# ============================================
# API ENDPOINTS (For Reference)
# ============================================
# Admin API: http://localhost:3001/api/admin
# User API: http://localhost:3001/api/user
# Swagger Docs: http://localhost:3001/api/docs

# ============================================
# FRONTEND PORTS (For Reference)
# ============================================
# Admin Apps: http://localhost:1500
# User Apps: http://localhost:1400
