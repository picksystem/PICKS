  adminAdditionalApproval Boolean  @default(false)
  adminApprover           String?
  signInStyle             String   @default("new")
  signUpStyle             String   @default("new")
  forgotPasswordStyle     String   @default("new")
  theme                   String   @default("System")
  updatedBy               Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

/// Singleton row that stores the full SerivceOps configuration document as JSON.
/// Downstream sections (priorities, statuses, SLAs, …) reference ticket type
/// keys from AdminTicketType so they stay in sync automatically.
model AdminConfiguration {
  id        Int      @id @default(autoincrement())
  data      Json     @default("{}")
  updatedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

