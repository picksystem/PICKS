model AdminServiceRequestComment {
  id                  Int      @id @default(autoincrement())
  serviceRequestId    Int
  serviceRequest      AdminServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  subject             String
  message             String
  isInternal          Boolean  @default(false)
  isSelfNote          Boolean  @default(false)
  notifyAssigneesOnly Boolean  @default(false)
  status              String?
  attachments         String?
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AdminServiceRequestTimeEntry {
  id               Int      @id @default(autoincrement())
  serviceRequestId Int
