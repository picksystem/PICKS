  createdBy          String
  isRecurring           Boolean   @default(false)
  isReleaseManagement   Boolean   @default(false)
  eta                   DateTime?
  notes                 String?
  relatedRecords     String?
  attachments        String?
  followers          String?
  internalFollowers  String?
  draftExpiresAt     DateTime?
  clientPrimaryContact   String?
  billingCode            String?
  approvedEstimatesHours Float?
  estimatesDetails       String?
  analysisSummary    String?
  ticketSource       String?
  resolvedAt         DateTime?
  resolvedBy         String?
  closedAt           DateTime?
  closedBy           String?
  reopenedAt         DateTime?
  reopenedBy         String?
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  comments           AdminServiceRequestComment[]
