// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth Models

// UserStatus: pending_approval | invited | active | inactive | deactivated | rejected | expired
// UserSource:  signup | admin | ticket | ad

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String    @unique
  password        String
  phone           String?
  workLocation    String?
  department      String?
  reasonForAccess String?
  employeeId      String?
  businessUnit    String?
  managerName     String?
  dateOfBirth     String?
  profilePicture  String?
  name            String
  role            String    @default("user")
  requestedRole   String?
  // lifecycle status
  status          String    @default("pending_approval")
  source          String    @default("signup")        // signup | admin | ticket | ad
  // approval
  reviewedBy      Int?
  reviewedAt      DateTime?
  adminNotes      String?
  // invitation
  invitationToken  String?
  invitationExpiry DateTime?
  // password management
  mustResetPassword       Boolean   @default(false)
  otp                     String?
  otpExpiresAt            DateTime?
  otpIsUsed               Boolean   @default(false)
  failedLoginAttempts     Int       @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  passwordChangedAt       DateTime?
  // access control
  isActive                Boolean   @default(false)
  accessFromDate          DateTime?
  accessToDate            DateTime?
  firstActivationDate     DateTime?
  lastDeactivationDate    DateTime?
  // tracking
  lastActivityAt          DateTime?
  // locale & preferences
  timezone                String?
  dateFormat              String?
  timeFormat              String?
  language                String?
  // consultant fields
  consultantProfileUpdated Boolean  @default(false)
  slaWorkingCalendar       String?
  slaExceptionGroup        String?
  application              String?
  applicationLead          String?
  // timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UserChangeLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  changeType    String   // field_update | role_change | access_approved | access_created | password_reset | activation | deactivation | rejection
  fieldName     String?
  previousValue String?
  newValue      String?
  changedBy     Int
  changedByName String
  reasonCode    String?
  reasonNotes   String?
  createdAt     DateTime @default(now())
}

model ConsultantProfile {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  application          String
  consultantRole       String?
  slaWorkingCalendar   String?
  slaExceptionCalendar String?
  leadConsultant       String?
  applicationManager   String?
  isPocLead            Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ConsultantRole {
  id          Int      @id @default(autoincrement())
  application String
  roleName    String
  description String?
  createdAt   DateTime @default(now())
}

model LoginLog {
  id         Int       @id @default(autoincrement())
  userId     Int
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  ipAddress  String?
  device     String?
  userAgent  String?
}

// ADMIN API Models

model AdminDashboard {
  id   String @id @default(cuid())
  name String
  age  Int
}

model AdminHeader {
  id          Int      @id @default(autoincrement())
  ticketType  String
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  app         String
  order       Int
}

model AdminTicketType {
  id           Int     @id @default(autoincrement())
  type         String  @unique
  name         String
  displayName  String  @default("")
  description  String  @default("")
  prefix       String  @default("")
  isActive     Boolean @default(true)
  numberLength Int     @default(7)
}

model AdminIncident {
  id                 Int      @id @default(autoincrement())
  number             String   @unique
  client             String?
  caller             String
  callerPhone        String?
  callerEmail        String?
  callerLocation     String?
  callerDepartment   String?
  additionalContacts String?
  businessCategory   String?
  serviceLine        String?
  application        String?
  applicationCategory    String?
  applicationSubCategory String?
  shortDescription   String?
  description        String?
  impact             String?
  urgency            String?
  priority           String?
  channel            String?
  status             String   @default("new")
  assignmentGroup    String?
  primaryResource    String?
  secondaryResources String?
  createdBy          String
  isRecurring           Boolean   @default(false)
  isMajor               Boolean   @default(false)
  isReleaseManagement   Boolean   @default(false)
  eta                   DateTime?
  notes                 String?
  relatedRecords     String?
  attachments        String?
  followers          String?
  internalFollowers  String?
  draftExpiresAt     DateTime?
  // Contact & Billing
  clientPrimaryContact   String?
  billingCode            String?
  approvedEstimatesHours Float?
  estimatesDetails       String?
  // Reporting
  analysisSummary    String?
  ticketSource       String?
  // Audit timestamps (system-set when status changes)
  resolvedAt         DateTime?
  resolvedBy         String?
  closedAt           DateTime?
  closedBy           String?
  reopenedAt         DateTime?
  reopenedBy         String?
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  comments           AdminIncidentComment[]
  timeEntries        AdminIncidentTimeEntry[]
  resolutions        AdminIncidentResolution[]
  activities         AdminIncidentActivity[]
}

model AdminIncidentComment {
  id                  Int      @id @default(autoincrement())
  incidentId          Int
  incident            AdminIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  subject             String
  message             String
  isInternal          Boolean  @default(false)
  isSelfNote          Boolean  @default(false)
  notifyAssigneesOnly Boolean  @default(false)
  status              String?
  attachments         String?
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AdminIncidentTimeEntry {
  id              Int      @id @default(autoincrement())
  incidentId      Int
  incident        AdminIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  date            String
  hours           Int
  minutes         Int
  billingCode     String?
  activityTask    String?
  externalComment String?
  internalComment String?
  isNonBillable   Boolean  @default(false)
  attachments     String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminIncidentResolution {
  id                   Int      @id @default(autoincrement())
  incidentId           Int
  incident             AdminIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  application          String?
  category             String?
  subCategory          String?
  customerConfirmation Boolean  @default(false)
  isRecurring          Boolean  @default(false)
  rootCauseIdentified  Boolean  @default(false)
  rootCause            String?
  resolutionCode       String
  resolution           String
  internalNote         String?
  attachments          String?
  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AdminIncidentActivity {
  id            Int      @id @default(autoincrement())
  incidentId    Int
  incident      AdminIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  activityType  String
  description   String
  previousValue String?
  newValue      String?
  performedBy   String
  createdAt     DateTime @default(now())
}

