{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts"],
    "jsx": "react-jsx"
  },
  "exclude": [
    "**/*.stories.ts",
    "**/*.test.ts",
    "**/*.stories.tsx",
    "**/*.test.tsx",
    "**/*.stories.js",
    "**/*.test.js",
    "**/*.stories.jsx",
    "**/*.test.jsx",
    "jest.config.ts",
    "jest.config.cts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
