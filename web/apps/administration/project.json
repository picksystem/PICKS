{
  "name": "administration",
  "root": "web/apps/administration",
  "sourceRoot": "web/apps/administration/src",
  "projectType": "application",
  "tags": ["app"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "outputPath": "dist/web/apps/administration",
        "configFile": "web/apps/administration/vite.config.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "administration:build"
      }
    }
  }
}
