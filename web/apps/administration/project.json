{
  "name": "administration",
  "root": "web/apps/administration",
  "sourceRoot": "web/apps/administration/src",
  "projectType": "application",
  "tags": ["app"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "options": {
        "outputPath": "dist/web/apps/administration",
        "index": "web/apps/administration/src/index.html",
        "main": "web/apps/administration/src/main.tsx",
        "tsConfig": "web/apps/administration/tsconfig.app.json",
        "webpackConfig": "web/apps/administration/webpack.config.js"
      }
    },
    "serve": {
      "executor": "@nx/webpack:dev-server",
      "options": {
        "buildTarget": "administration:build",
        "hmr": true,
        "port": 4200,
        "historyApiFallback": true
      }
    }
  }
}
