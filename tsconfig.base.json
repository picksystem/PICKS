{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["es2020", "esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "module": "esnext",
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types", "./typings"],
    "paths": {
      "@serviceops/component": ["./libs/ui/components/index.ts"],
      "@serviceops/component/*": ["./libs/ui/components/*"],
      "@serviceops/theme": ["./libs/theme/index.ts"],
      "@serviceops/interfaces": ["./libs/entities/index.ts"],
      "@serviceops/hooks": ["./libs/ui/hooks/index.ts"],
      "@serviceops/utils": ["./libs/utils/index.ts"],
      "@serviceops/pages/*": ["./libs/ui/pages/*"],
      "@serviceops/constants": ["./libs/shared/constants/index.ts"],
      "@serviceops/middleware": ["./libs/core/middleware/index.ts"],
      "@serviceops/config": ["./libs/core/config/index.ts"],
      "@serviceops/database": ["./libs/core/database/index.ts"],
      "@serviceops/core": ["./libs/core/index.ts"],
      "@serviceops/core/repository": ["./libs/core/repository/index.ts"],
      "@serviceops/core/service": ["./libs/core/service/index.ts"],
      "@serviceops/core/validation": ["./libs/core/validation/index.ts"],
      "@serviceops/core/gateways": ["./libs/core/gateways/index.ts"],
      "@serviceops/core/infrastructure": ["./libs/core/infrastructure/index.ts"],
      "@serviceops/core/use-cases": ["./libs/core/use-cases/index.ts"],
      "@serviceops/mocks": ["./libs/ui/mocks/index.ts"],
      "@serviceops/services": ["./libs/services/index.ts"],
      "@serviceops/store": ["./libs/ui/store/index.ts"],
      "@serviceops/slices": ["./libs/ui/slices/index.ts"],
      "@serviceops/state": ["./libs/ui/state/index.ts"],
      "@serviceops/genericpanel": ["./libs/ui/pages/base/Configuration/shared/GenericPanel/GenericPanel"],
      "@serviceops/configdialogs": ["./libs/ui/pages/base/Configuration/dialogs/ConfigDialogs/ConfigDialogs"],
      "@serviceops/configsection": ["./libs/ui/pages/base/Configuration/shared/ConfigurationSection/ConfigurationSection"],
      "@serviceops/generictablepanel": ["./libs/ui/pages/base/Configuration/shared/GenericTablePanel/GenericTablePanel"],
      "@serviceops/generictoolbar": ["./libs/ui/pages/base/Configuration/shared/GenericToolbar/GenericToolbar"],
      "@serviceops/generictogglepanel": ["./libs/ui/pages/base/Configuration/shared/GenericTogglePanel/GenericTogglePanel"],
      "@serviceops/genericaccordion": ["./libs/ui/pages/base/Configuration/shared/GenericAccordion/GenericAccordion"],
      "@serviceops/configplaceholder": ["./libs/ui/pages/base/Configuration/shared/ConfigPlaceholder/ConfigPlaceholder"],
      "@serviceops/richtexteditor": ["./libs/ui/pages/base/Configuration/shared/RichTextEditor/RichTextEditor"],
      "@serviceops/configbase": ["./libs/ui/pages/base/Configuration/shared/styles/ConfigurationBase.styles.shared"],
      "@serviceops/confighooks": ["./libs/ui/pages/base/Configuration/hooks/useConfiguration"],
      "@serviceops/configutils": ["./libs/ui/pages/base/Configuration/utils/cellRenderers"],
      "@serviceops/configpriorityutil": ["./libs/ui/pages/base/Configuration/sections/Priorities/util"],
      "@serviceops/configtickettypetable": ["./libs/ui/pages/base/Configuration/components/TicketTypeTable/TicketTypeTable"],
      "@serviceops/configtickettypeformdialog": ["./libs/ui/pages/base/Configuration/dialogs/TicketTypeFormDialog/TicketTypeFormDialog"],
      "@serviceops/configsequencedialog": ["./libs/ui/pages/base/Configuration/dialogs/SequenceDialog/SequenceDialog"],
      "@serviceops/configtickettypeicons": ["./libs/ui/pages/base/Configuration/utils/ticketTypeIcons"],
      "@serviceops/configprioritformdialog": ["./libs/ui/pages/base/Configuration/dialogs/PriorityFormDialog/PriorityFormDialog"],
      "@serviceops/configcatorshared": ["./libs/ui/pages/base/Configuration/sections/Categorization/components/shared"],
      "@serviceops/configtimesheetshared": ["./libs/ui/pages/base/Configuration/components/shared/TimesheetsPanelConfig"]
    }
  },
  "exclude": ["dist", "node_modules", "temp"]
}
